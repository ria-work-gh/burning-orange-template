{%- comment -%} Tab panel — JS reads data attributes to build nav buttons {%- endcomment -%}

<div
  class="tabs-panel"
  role="tabpanel"
  id="panel-{{ block.id }}"
  aria-labelledby="tab-{{ block.id }}"
  data-tab-heading="{{ block.settings.heading | escape }}"
  data-tab-slug="{{ block.settings.heading | handleize }}"
  {%- if block.settings.image != blank -%}
    data-tab-image="{{ block.settings.image | image_url: width: 80 }}"
  {%- endif -%}
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>

{% schema %}
{
  "name": "Tab",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Tab heading",
      "default": "Product name"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Tab image"
    }
  ],
  "blocks": [
    { "type": "step" }
  ],
  "presets": [
    {
      "name": "Tab",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "text": "<p>Describe this care step.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
