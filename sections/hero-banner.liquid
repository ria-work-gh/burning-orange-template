{%- comment -%} Hero banner: full-viewport image with text and product pill blocks. {%- endcomment -%}
<div class="hero-banner{% if section.settings.height == 'compact' %} compact{% endif %}">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 2400
      | image_tag:
        loading: 'eager',
        sizes: '100vw',
        width: section.settings.image.width,
        height: section.settings.image.height
    }}
  {%- endif -%}

  <div class="hero-overlay" style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>

  {%- for block in section.blocks -%}
    {%- if block.type == 'text' -%}
      {%- if block.settings.text != blank or block.settings.button_url != blank -%}
        <div class="hero-text-block hero-align-{{ block.settings.alignment }} hero-valign-{{ block.settings.vertical_alignment }}" {{ block.shopify_attributes }}>
          <div class="hero-text-content">
            {%- if block.settings.text != blank -%}
              <p class="hero-text text-large">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.button_url != blank -%}
              <a href="{{ block.settings.button_url }}" class="button text-cap">{{ 'sections.hero.shop_now' | t }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- elsif block.type == 'product_pill' -%}
      {%- assign pill_product = block.settings.product -%}
      {%- if pill_product != blank -%}
        {%- liquid
          assign color_value = nil
          for option in pill_product.options_with_values
            assign option_name_lower = option.name | downcase
            if option_name_lower == 'color' or option_name_lower == 'colour'
              assign color_value = option.values | first
            endif
          endfor
        -%}
        <a href="{{ pill_product.url }}" class="hero-product-pill" {{ block.shopify_attributes }}>
          {%- if pill_product.featured_image != blank -%}
            <div class="pill-image">
              {{
                pill_product.featured_image
                | image_url: width: 300
                | image_tag:
                  loading: 'lazy',
                  width: pill_product.featured_image.width,
                  height: pill_product.featured_image.height
              }}
            </div>
          {%- endif -%}
          <div class="pill-content">
            <span class="pill-label text-light">{{ block.settings.label | default: 'Featured product' }}</span>
            <div class="pill-title">
              <h3>{{ pill_product.title }}</h3>
            </div>
            <span class="text-cap inline-link">{{ 'sections.hero.shop_now' | t }}</span>
          </div>
        </a>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
</div>

{% stylesheet %}
  .hero-banner {
    position: relative;
    height: 100dvh;
    margin-bottom: var(--spacing-4);
    overflow: hidden;
  }

  .hero-banner.compact {
    height: 75vh;
  }

  .hero-banner > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: hsla(0, 0%, 0%, var(--overlay-opacity, 0));
    pointer-events: none;
  }

  /* Text block */
  .hero-text-block {
    position: absolute;
    color: white;
    --tx: 0;
    --ty: 0;
    transform: translate(var(--tx), var(--ty));
  }

  /* Horizontal alignment */
  .hero-align-left { left: var(--spacing-2); text-align: left; }
  .hero-align-center { left: 50%; --tx: -50%; text-align: center; }
  .hero-align-right { right: var(--spacing-2); text-align: right; }

  /* Vertical alignment */
  .hero-valign-top { top: var(--spacing-2); }
  .hero-valign-middle { top: 50%; --ty: -50%; }
  .hero-valign-bottom { bottom: var(--spacing-2); }

  .hero-text-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    max-width: 80ch;
  }

  .hero-text {
    max-width: 45ch;
    text-wrap: balance;
  }

  @media (max-width: 749px) {
    .hero-valign-middle {
      left: var(--spacing-2);
      right: var(--spacing-2);
      width: auto;
      --tx: 0;
    }
  }

  /* Product pill — positioned wrapper using journal-card internals */
  .hero-product-pill {
    position: absolute;
    bottom: var(--spacing-2);
    right: var(--spacing-2);
    background-color: hsla(45, 33%, 85%, 0.85);
    backdrop-filter: blur(var(--blur-md));
    -webkit-backdrop-filter: blur(var(--blur-md));
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-1);
    padding: var(--spacing-1);
    width: clamp(280px, 30vw, 600px);
    text-decoration: none;
    color: inherit;
  }

  .hero-product-pill:hover .inline-link {
    color: var(--color-accent);
  }

  .hero-product-pill:hover img {
    transform: scale(1.03);
  }

  /* Product pill internals */
  .pill-image {
    overflow: hidden;
  }

  .pill-image img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .pill-content {
    display: grid;
    grid-template-rows: auto 1fr auto;
  }

  .pill-label {
    /* color: var(--color-text); */
  }

  .pill-title {
    /* align-self: center; */
  }

  @media (prefers-reduced-motion: reduce) {
    .pill-image img {
      transition: none;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "full", "label": "Full (100dvh)" },
        { "value": "compact", "label": "Compact (75vh)" }
      ],
      "default": "full"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Horizontal alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "vertical_alignment",
          "label": "Vertical alignment",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ],
          "default": "bottom"
        }
      ]
    },
    {
      "type": "product_pill",
      "name": "Product pill",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}
