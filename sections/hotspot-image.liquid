{%- comment -%} Hotspot image: full image with positioned hotspot markers and popovers. {%- endcomment -%}

{%- if section.settings.image != blank -%}
  <hotspot-image class="hotspot-section{% if section.settings.image_fill %} hotspot-section-fill{% endif %}{% if section.settings.mobile_cards %} hotspot-section-mobile-cards{% endif %} color-{{ section.settings.color_scheme }}">
    <div class="hotspot-container">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          class: 'hotspot-image',
          loading: 'lazy',
          sizes: '(min-width: 1000px) 1000px, 100vw',
          alt: section.settings.image.alt,
          width: section.settings.image.width,
          height: section.settings.image.height
      }}

      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank -%}
          {%- assign hotspot_label = 'sections.hotspot_image.hotspot_label' | t: title: block.settings.title -%}
        {%- else -%}
          {%- assign hotspot_label = 'sections.hotspot_image.hotspot_label_generic' | t -%}
        {%- endif -%}

        <div class="hotspot-point" style="left: {{ block.settings.x }}%; top: {{ block.settings.y }}%;" {{ block.shopify_attributes }}>
          <button
            class="hotspot-marker"
            data-hotspot="{{ block.id }}"
            aria-expanded="false"
            aria-controls="hotspot-content-{{ block.id }}"
            aria-label="{{ hotspot_label }}"
          >
            <svg class="hotspot-plus" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M10 2V18M2 10H18" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="hotspot-popover" id="hotspot-content-{{ block.id }}" aria-hidden="true">
            {%- if block.settings.title != blank -%}
              <h3 class="hotspot-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="hotspot-description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

      {%- if section.settings.mobile_cards -%}
        <div class="hotspot-cards">
          <div class="hotspot-cards-viewport">
            <div class="hotspot-cards-container">
              {%- for block in section.blocks -%}
                <div class="hotspot-card" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <h3 class="hotspot-card-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="hotspot-card-description">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </hotspot-image>

  <script type="module" src="{{ 'hotspot-image.js' | asset_url }}"></script>
  {%- if section.settings.mobile_cards -%}
    <script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .hotspot-section {
    background-color: var(--color-input-bg);
    height: 85vh;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hotspot-container {
    position: relative;
    max-width: 1000px;
    max-height: 100%;
  }

  .hotspot-image {
    max-width: 100%;
    max-height: calc(85vh - var(--spacing-2) * 2);
    object-fit: contain;
    display: block;
  }

  .hotspot-point {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .hotspot-point.is-active {
    z-index: 2;
  }

  .hotspot-marker {
    width: 40px;
    height: 40px;
    background-color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .hotspot-plus {
    display: block;
    flex-shrink: 0;
  }

  .hotspot-popover {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.96);
    width: 300px;
    box-sizing: border-box;
    padding: var(--spacing-1);
    text-align: left;
    background-color: color-mix(in srgb, var(--color-input-bg-pressed) 85%, transparent);
    backdrop-filter: blur(var(--blur-md));
    -webkit-backdrop-filter: blur(var(--blur-md));
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .hotspot-popover.is-active {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    pointer-events: auto;
  }

  .hotspot-title {
    font-size: var(--font-base-size);
    line-height: var(--font-base-height);
    font-weight: normal;
    color: var(--color-text);
    margin-bottom: var(--spacing-1);
  }

  .hotspot-description {
    font-size: var(--font-mini-size);
    line-height: var(--font-mini-height);
    color: var(--color-text);
  }

  .hotspot-section-fill {
    padding: 0;
  }

  .hotspot-section-fill .hotspot-container {
    width: 100%;
    max-width: none;
    height: 100%;
  }

  .hotspot-section-fill .hotspot-image {
    width: 100%;
    height: 100%;
    max-height: none;
    object-fit: cover;
  }

  @media (max-width: 749px) {
    .hotspot-section {
      height: auto;
      aspect-ratio: 3 / 4;
    }

    .hotspot-marker {
      width: 32px;
      height: 32px;
    }

    .hotspot-plus {
      width: 16px;
      height: 16px;
    }

    .hotspot-popover {
      width: 250px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hotspot-popover {
      transition: none;
    }
  }

  .hotspot-cards {
    display: none;
  }

  @media (max-width: 749px) {
    .hotspot-section-mobile-cards .hotspot-point {
      display: none;
    }

    .hotspot-section-mobile-cards .hotspot-container {
      position: relative;
    }

    .hotspot-section-mobile-cards .hotspot-cards {
      display: block;
      position: absolute;
      bottom: var(--spacing-1);
      left: 0;
      right: 0;
      overflow: hidden;
      z-index: 1;
    }

    .hotspot-cards-viewport {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      margin-left: var(--spacing-1);
    }

    .hotspot-cards-container {
      display: flex;
      gap: var(--spacing-1);
      padding-right: var(--spacing-1);
    }

    .hotspot-card {
      flex: 0 0 calc(80% - var(--spacing-1));
      min-width: 0;
      scroll-snap-align: start;
      background-color: color-mix(in srgb, var(--color-input-bg-pressed) 85%, transparent);
      backdrop-filter: blur(var(--blur-md));
      -webkit-backdrop-filter: blur(var(--blur-md));
      padding: var(--spacing-1);
    }

    .hotspot-card-title {
      font-size: var(--font-base-size);
      line-height: var(--font-base-height);
      margin-bottom: var(--spacing-1);
    }

    .hotspot-card-description {
      font-size: var(--font-mini-size);
      line-height: var(--font-base-height);
      color: var(--color-text);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hotspot image",
  "tag": "section",
  "class": "hotspot-image-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "checkbox",
      "id": "image_fill",
      "label": "Image fill container",
      "info": "Hotspot positions may shift slightly in fill mode due to image cropping",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "mobile_cards",
      "label": "Show as cards on mobile",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "limit": 8,
      "settings": [
        {
          "type": "range",
          "id": "x",
          "label": "Horizontal position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "y",
          "label": "Vertical position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["index"]
  },
  "presets": [
    {
      "name": "Hotspot image"
    }
  ]
}
{% endschema %}
