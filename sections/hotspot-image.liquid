{%- comment -%} Hotspot image: full image with positioned hotspot markers and popovers. {%- endcomment -%}

{%- if section.settings.image != blank -%}
  <hotspot-image class="hotspot-section color-{{ section.settings.color_scheme }}">
    <div class="hotspot-container" style="--image-w: {{ section.settings.image.width }}; --image-h: {{ section.settings.image.height }}">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          class: 'hotspot-image',
          loading: 'lazy',
          sizes: '(min-width: 1000px) 1000px, 100vw',
          alt: section.settings.image.alt,
          width: section.settings.image.width,
          height: section.settings.image.height
      }}

      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank -%}
          {%- assign hotspot_label = 'sections.hotspot_image.hotspot_label' | t: title: block.settings.title -%}
        {%- else -%}
          {%- assign hotspot_label = 'sections.hotspot_image.hotspot_label_generic' | t -%}
        {%- endif -%}

        <div class="hotspot-point" style="left: {{ block.settings.x }}%; top: {{ block.settings.y }}%;" {{ block.shopify_attributes }}>
          <button
            class="hotspot-marker"
            data-hotspot="{{ block.id }}"
            aria-expanded="false"
            aria-controls="hotspot-content-{{ block.id }}"
            aria-label="{{ hotspot_label }}"
          >
            <svg class="hotspot-plus" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false">
              <path d="M10 2V18M2 10H18" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="hotspot-popover" id="hotspot-content-{{ block.id }}" aria-hidden="true">
            {%- if block.settings.title != blank -%}
              <h3 class="hotspot-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="hotspot-description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}

    </div>
  </hotspot-image>

  <script type="module" src="{{ 'hotspot-image.js' | asset_url }}"></script>
{%- endif -%}

{% stylesheet %}
  .hotspot-section {
    background-color: var(--color-input-bg);
    height: 85vh;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hotspot-container {
    position: relative;
    container-type: inline-size;
    aspect-ratio: var(--image-w) / var(--image-h);
    --max-h: calc(85vh - var(--spacing-2) * 2);
    width: min(100%, 1000px, calc(var(--max-h) * var(--image-w) / var(--image-h)));
    max-height: var(--max-h);
  }

  .hotspot-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hotspot-point {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .hotspot-point.is-active {
    z-index: 2;
  }

  .hotspot-marker {
    width: clamp(28px, 4cqi, 44px);
    height: clamp(28px, 4cqi, 44px);
    background-color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .hotspot-plus {
    display: block;
    flex-shrink: 0;
    width: 50%;
    height: 50%;
  }

  .hotspot-popover {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.96);
    width: 300px;
    box-sizing: border-box;
    padding: var(--spacing-1);
    text-align: left;
    background-color: color-mix(in srgb, var(--color-input-bg-pressed) 85%, transparent);
    backdrop-filter: blur(var(--blur-md));
    -webkit-backdrop-filter: blur(var(--blur-md));
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .hotspot-popover.is-active {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    pointer-events: auto;
  }

  .hotspot-title {
    font-size: var(--font-base-size);
    line-height: var(--font-base-height);
    font-weight: normal;
    color: var(--color-text);
    margin-bottom: var(--spacing-1);
  }

  .hotspot-description {
    font-size: var(--font-mini-size);
    line-height: var(--font-mini-height);
    color: var(--color-text);
  }

  @media (max-width: 749px) {
    .hotspot-section {
      height: auto;
    }

    .hotspot-popover {
      width: 250px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hotspot-popover {
      transition: none;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Hotspot image",
  "tag": "section",
  "class": "hotspot-image-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "limit": 8,
      "settings": [
        {
          "type": "range",
          "id": "x",
          "label": "Horizontal position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "y",
          "label": "Vertical position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["index"]
  },
  "presets": [
    {
      "name": "Hotspot image"
    }
  ]
}
{% endschema %}
