{%- comment -%}
  Password page — newsletter-forward design.
  Logo top-aligned, content centered, admin footer bottom-aligned.
{%- endcomment -%}
<div class="password color-{{ section.settings.color_scheme }}">
  <header class="password-header">
    <a href="/" class="password-logo" aria-label="{{ shop.name }}">
      {%- render 'logo', logo: section.settings.logo, class: 'password-logo-inner' -%}
    </a>
  </header>

  <div class="password-body">
    <h1 class="password-heading text-cap">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        {{ 'password.general.title' | t }}
      {%- endif -%}
    </h1>

    {%- if section.settings.message != blank -%}
      <div class="password-message typeset">
        {{ section.settings.message }}
      </div>
    {%- else -%}
      <p class="password-message">
        {{ 'password.general.message' | t }}
      </p>
    {%- endif -%}

    {%- if section.settings.show_newsletter -%}
      <div class="password-newsletter">
        {%- render 'newsletter-form' -%}
      </div>
    {%- endif -%}
  </div>

  <footer class="password-footer">
    <details class="password-access text-mini text-light">
      <summary class="password-access-toggle inline-link">{{ 'password.general.enter_with_password' | t }}</summary>
      <div class="password-access-form">
        {%- form 'storefront_password', class: 'password-form' -%}
          {%- if form.errors -%}
            <div class="form-error" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
          <div class="form-inline">
            <label for="password-input" class="visually-hidden">
              {{ 'password.general.password_label' | t }}
            </label>
            <input
              type="password"
              id="password-input"
              name="password"
              class="input"
              placeholder="{{ 'password.general.password_placeholder' | t }}"
              required
            >
            <button type="submit" class="button text-cap">
              {{ 'password.general.enter' | t }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </details>
  </footer>
</div>

{% stylesheet %}
  .password-section {
    min-height: 100vh;
    min-height: 100dvh;
  }

  .password {
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    padding: var(--spacing-3) var(--spacing-2);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .password-header {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .password-logo {
    display: block;
  }

  .password-logo-inner svg,
  .password-logo-inner img {
    height: 28px;
    width: auto;
  }

  .password-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 480px;
    width: 100%;
  }

  .password-heading {
    margin-bottom: var(--spacing-1);
  }

  .password-message {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-3);
  }

  .password-newsletter {
    width: 100%;
  }

  .password-footer {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-1);
    padding-top: var(--spacing-3);
  }

  .password-access {
    cursor: pointer;
  }

  .password-access-toggle {
    list-style: none;
  }

  .password-access-toggle::-webkit-details-marker {
    display: none;
  }

  .password-access-form {
    margin-top: var(--spacing-2);
  }

  .password-form .form-error {
    margin-bottom: var(--spacing-2);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "password-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use default translation"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "Message",
      "info": "Leave blank to use default translation"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
