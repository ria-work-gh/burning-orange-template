{%- comment -%}
  Password page — holding-site design.
  Full-viewport backdrop, cream typography, newsletter-forward CTA.
  Admin password entry lives in the footer disclosure.
{%- endcomment -%}
<div class="password">
  {%- if section.settings.background_image != blank -%}
    {{
      section.settings.background_image
      | image_url: width: 2400
      | image_tag:
        class: 'password-bg',
        loading: 'eager',
        sizes: '100vw',
        alt: '',
        width: section.settings.background_image.width,
        height: section.settings.background_image.height
    }}
  {%- endif -%}

  <header class="password-header">
    <a href="{{ routes.root_url }}" class="password-logo" aria-label="{{ shop.name }}">
      {%- render 'logo', logo: section.settings.logo, class: 'password-logo-inner' -%}
    </a>
  </header>

  <div class="password-tagline">
    <img
      src="{{ 'text-span.svg' | asset_url }}"
      alt=""
      role="presentation"
      width="444"
      height="283"
      loading="eager"
    >
  </div>

  <footer class="password-footer">
    {%- if section.settings.show_newsletter -%}
      <div class="password-newsletter">
        {%- render 'newsletter-form' -%}
        {%- if section.settings.newsletter_notice != blank -%}
          <div class="password-notice typeset">
            {{ section.settings.newsletter_notice }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <details class="password-access">
      <summary class="password-access-toggle">
        {{ 'password.general.enter_with_password' | t }}
      </summary>
      <div class="password-access-form">
        {%- form 'storefront_password' -%}
          {%- if form.errors -%}
            <div class="form-error" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
          <div class="form-inline">
            <label for="password-input" class="visually-hidden">
              {{ 'password.general.password_label' | t }}
            </label>
            <input
              type="password"
              id="password-input"
              name="password"
              class="input"
              placeholder="{{ 'password.general.password_placeholder' | t }}"
              required
            >
            <button type="submit" class="button text-cap">
              {{ 'password.general.enter' | t }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </details>
  </footer>
</div>

{% stylesheet %}
  .password-section {
    min-height: 100vh;
    min-height: 100dvh;
  }

  .password {
    --pw-cream: #fdfdf4;
    --pw-orange: #c96a3a;
    --pw-accent: #e6815b;

    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    padding: var(--spacing-3) var(--spacing-2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    text-align: center;
    background-color: var(--pw-orange);
    color: var(--pw-cream);
    font-family: 'Litteratur', serif;
    overflow: hidden;
    animation: password-fade-in 250ms ease-out;
  }

  @keyframes password-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .password {
      animation: none;
    }
  }

  .password-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .password::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.05);
    pointer-events: none;
    z-index: 0;
  }

  .password-header,
  .password-tagline,
  .password-footer {
    position: relative;
    z-index: 1;
  }

  .password-header {
    display: flex;
    justify-content: center;
    padding: var(--spacing-1) 0;
  }

  .password-logo {
    display: inline-block;
    color: var(--pw-cream);
  }

  .password-logo-inner {
    display: inline-block;
  }

  .password-logo-inner img,
  .password-logo-inner svg {
    display: block;
    max-width: 280px;
    max-height: 80px;
    width: auto;
    height: auto;
  }

  .password-tagline {
    width: 100%;
    max-width: 65ch;
    padding: 0 var(--spacing-2);
    display: flex;
    justify-content: center;
  }

  .password-tagline img {
    width: 100%;
    max-width: 560px;
    height: auto;
  }

  .password-footer {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-2);
  }

  .password-newsletter {
    width: 100%;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-2);
  }

  .password-newsletter .newsletter-input-wrap {
    position: relative;
    display: flex;
    align-items: stretch;
    gap: 8px;
    padding: 6px;
    width: 100%;
    background-color: var(--pw-cream);
    box-sizing: border-box;
  }

  .password-newsletter .input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 6px;
    background: transparent;
    border: 0;
    color: #000;
    font-family: inherit;
    font-size: 14px;
  }

  .password-newsletter .input:hover,
  .password-newsletter .input:focus {
    background: transparent;
    outline: none;
  }

  .password-newsletter .input::placeholder {
    color: #000;
    opacity: 0.6;
  }

  .password-newsletter .newsletter-submit {
    position: static;
    padding: 6px 12px;
    background: transparent;
    color: #000;
    border: 0;
    font-family: inherit;
    font-size: 14px;
    letter-spacing: 0.1em;
    transition: background-color 200ms, color 200ms;
    cursor: pointer;
  }

  .password-newsletter .newsletter-submit:hover,
  .password-newsletter .newsletter-submit:focus-visible {
    background-color: var(--pw-accent);
    color: var(--pw-cream);
  }

  .password-newsletter .form-success,
  .password-newsletter .form-error {
    color: var(--pw-cream);
    text-align: center;
  }

  .password-notice {
    max-width: 40ch;
    line-height: 1.2;
    font-size: 14px;
    text-align: center;
    text-wrap: balance;
  }

  .password-access {
    margin-top: var(--spacing-2);
  }

  .password-access-toggle {
    list-style: none;
    cursor: pointer;
    font-size: 12px;
    color: var(--pw-cream);
    opacity: 0.7;
    transition: opacity 200ms;
  }

  .password-access-toggle:hover,
  .password-access-toggle:focus-visible {
    opacity: 1;
  }

  .password-access-toggle::-webkit-details-marker {
    display: none;
  }

  .password-access-form {
    margin-top: var(--spacing-1);
  }

  .password-access-form .form-inline {
    display: flex;
    gap: 8px;
    padding: 6px;
    max-width: 360px;
    margin: 0 auto;
    background-color: var(--pw-cream);
  }

  .password-access-form .input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 6px;
    background: transparent;
    border: 0;
    color: #000;
    font-family: inherit;
    font-size: 14px;
  }

  .password-access-form .input:hover,
  .password-access-form .input:focus {
    background: transparent;
    outline: none;
  }

  .password-access-form .button {
    padding: 6px 12px;
    background: transparent;
    color: #000;
    border: 0;
    font-family: inherit;
    font-size: 14px;
    letter-spacing: 0.1em;
    transition: background-color 200ms, color 200ms;
    cursor: pointer;
  }

  .password-access-form .button:hover,
  .password-access-form .button:focus-visible {
    background-color: var(--pw-accent);
    color: var(--pw-cream);
  }

  .password-access .form-error {
    color: var(--pw-cream);
    margin-bottom: var(--spacing-1);
  }

  @media (max-width: 900px) {
    .password {
      padding: var(--spacing-2);
    }

    .password-logo-inner img,
    .password-logo-inner svg {
      max-width: 220px;
      max-height: 60px;
    }
  }

  @media (max-width: 600px) {
    .password-tagline img {
      max-width: 320px;
    }

    .password-newsletter .input,
    .password-newsletter .newsletter-submit,
    .password-notice {
      font-size: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "password-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Uses the theme logo style. Leave blank to use the default wordmark."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Leave blank to show a solid color only."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "richtext",
      "id": "newsletter_notice",
      "label": "Newsletter notice",
      "default": "<p>Join the mailing list for the first look at new collections and styling advice.</p>"
    }
  ]
}
{% endschema %}
