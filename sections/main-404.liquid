{%- comment -%} 404 page — minimal full-viewport centered layout {%- endcomment -%}
<div class="page-404 color-{{ section.settings.color_scheme }}">
  {%- if section.settings.image != blank -%}
    <div class="page-404-image">
      {{ section.settings.image | image_url: width: 400 | image_tag:
          loading: 'eager',
          width: section.settings.image.width,
          height: section.settings.image.height
      }}
    </div>
  {%- endif -%}

  <h1 class="page-404-heading text-cap">
    {{ section.settings.heading }}
  </h1>

  <p class="page-404-message">
    {{ section.settings.subheading }}
  </p>

  <a href="/" class="text-link text-cap">{{ 'not_found.general.back_home' | t }}</a>
</div>

{% stylesheet %}
  .page-404-section {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-404 {
    padding: var(--spacing-3) var(--spacing-2);
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .page-404-image {
    max-width: 200px;
    margin-bottom: var(--spacing-2);
  }

  .page-404-image img {
    width: 100%;
    height: auto;
  }

  .page-404-message {
    margin-top: var(--spacing-1);
    color: var(--color-text-light);
  }

  .page-404 > a {
    margin-top: var(--spacing-3);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "page-404-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page not found"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Message",
      "default": "The page you're looking for doesn't exist."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
