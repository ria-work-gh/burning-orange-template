{%- comment -%} Featured products: static grid of product cards from a collection. {%- endcomment -%}
<div class="featured-products{% if section.settings.color_scheme != blank %} color-{{ section.settings.color_scheme }}{% endif %}">
  {%- if section.settings.heading != blank -%}
    <h2 class="text-medium">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.settings.collection != blank -%}
    {%- if section.settings.enable_carousel -%}
      <product-carousel aria-roledescription="carousel" aria-label="{{ 'sections.featured_collection.carousel_label' | t }}">
        <div class="product-carousel-viewport">
          <div class="product-carousel-container">
            {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
              <div class="product-carousel-slide" role="group" aria-roledescription="slide" aria-label="{{ forloop.index }} / {{ forloop.length }}">
                {% render 'product-card', product: product %}
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="product-carousel-controls">
          <button class="product-carousel-prev" type="button" aria-label="{{ 'sections.featured_collection.previous' | t }}" disabled>
            {% render 'icon-chevron' %}
          </button>
          <button class="product-carousel-next" type="button" aria-label="{{ 'sections.featured_collection.next' | t }}">
            {% render 'icon-chevron' %}
          </button>
        </div>

        <div class="product-carousel-live visually-hidden" aria-live="polite"></div>
      </product-carousel>

      <script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>
      <script src="{{ 'product-carousel.js' | asset_url }}" defer></script>
    {%- else -%}
      <div class="product-grid">
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="product-grid">
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="placeholder-card" aria-hidden="true"></div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .featured-products {
    margin-block: var(--spacing-4);
    padding: var(--spacing-2);
    display: grid;
    gap: var(--spacing-2);
  }

  .placeholder-card {
    aspect-ratio: 3 / 4;
    background: var(--color-input-bg);
  }

  /* Carousel layout */
  .product-carousel-viewport {
    overflow: hidden;
  }

  .product-carousel-container {
    display: flex;
    gap: var(--spacing-2);
  }

  .product-carousel-slide {
    flex: 0 0 calc(50% - var(--spacing-2) / 2);
    min-width: 0;
  }

  @media (min-width: 750px) {
    .product-carousel-slide {
      flex: 0 0 calc(33.333% - var(--spacing-2) * 2 / 3);
    }
  }

  @media (min-width: 1024px) {
    .product-carousel-slide {
      flex: 0 0 calc(25% - var(--spacing-2) * 3 / 4);
    }
  }

  .product-carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: var(--spacing-1);
    padding-top: var(--spacing-2);
  }

  .product-carousel-prev,
  .product-carousel-next {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-text);
    transition: opacity var(--transition-fast);
  }

  .product-carousel-prev:disabled,
  .product-carousel-next:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .product-carousel-prev:not(:disabled):hover,
  .product-carousel-next:not(:disabled):hover {
    background: var(--color-text);
    color: var(--color-background);
  }

  .product-carousel-prev .icon {
    transform: rotate(90deg);
  }

  .product-carousel-next .icon {
    transform: rotate(-90deg);
  }

  /* No-JS fallback */
  product-carousel:not(.is-initialized) .product-carousel-viewport {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  product-carousel:not(.is-initialized) .product-carousel-controls {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-carousel-container {
      transition: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "label": "Enable carousel",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
