{%- comment -%} Tabs section — JS builds nav buttons from panel data attributes {%- endcomment -%}

<div class="tabs color-{{ section.settings.color_scheme }}">
  {%- if section.blocks.size > 0 -%}
    <div class="tabs-layout">
      <div class="tabs-nav">
        <div class="tabs-nav-container" role="tablist" aria-label="{{ 'sections.tabs.navigation' | t }}"></div>
      </div>
      <div class="tabs-panels">
        {% content_for 'blocks' %}
      </div>
    </div>
  {%- endif -%}
</div>

<noscript>
  <style>
    .tabs-nav { display: none; }
    .tabs-panel { display: flex !important; flex-direction: column; gap: var(--spacing-3); }
  </style>
</noscript>

{% stylesheet %}
  .tabs {
    width: 100%;
    padding: var(--spacing-2) var(--spacing-2) var(--spacing-4);
  }

  @media (min-width: 900px) {
    .tabs {
      width: 83%;
      max-width: 1200px;
      margin-inline: auto;
      padding: var(--spacing-2) 0 var(--spacing-5);
    }
  }

  /* Side-by-side layout: nav left, panels right */
  .tabs-layout {
    display: grid;
    gap: var(--spacing-3);
  }

  @media (min-width: 900px) {
    .tabs-layout {
      grid-template-columns: repeat(10, 1fr);
      column-gap: 0;
    }

    .tabs-nav {
      grid-column: 1 / span 3;
      position: sticky;
      top: var(--header-height, 80px);
      align-self: start;
    }

    .tabs-panels {
      grid-column: 5 / span 6;
    }
  }

  /* Tab navigation */
  .tabs-nav-container {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .tabs-button {
    display: flex;
    align-items: center;
    gap: var(--spacing-1);
    padding: var(--spacing-1) 0;
    font-family: inherit;
    font-size: var(--font-medium-size);
    color: var(--color-text);
    background: none;
    border: none;
    cursor: pointer;
    opacity: 0.35;
    transition: opacity var(--transition-fast);
  }

  .tabs-button-image {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .tabs-button:hover {
    opacity: 0.65;
  }

  .tabs-button.is-active {
    opacity: 1;
  }

  .tabs-button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  @media (min-width: 900px) {
    .tabs-button {
      text-align: left;
    }
  }

  /* Panels */
  .tabs-panel {
    display: none;
    counter-reset: step-counter;
  }

  .tabs-panel.is-active {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  /* Steps */
  .tabs-step {
    counter-increment: step-counter;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-2);
    align-items: baseline;
    margin-bottom: var(--spacing-3);
  }

  .tabs-step:last-child {
    margin-bottom: 0;
  }

  .tabs-step-number {
    font-family: var(--font-heading);
    font-size: var(--font-large-size);
    line-height: var(--font-large-height);
  }

  .tabs-step-number::before {
    content: counter(step-counter);
  }

  .tabs-step-content {
    display: flex;
    flex-direction: column;
  }

  .tabs-step-label {
    font-size: var(--font-mini-size);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-2);
  }

  .tabs-step-text {
    font-size: var(--font-medium-size);
    max-width: 60ch;
  }

  .tabs-step-media {
    margin-top: var(--spacing-1);
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .tabs-step-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tabs-step-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-1);
    margin-top: var(--spacing-1);
  }

  .tabs-step-split-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .tabs-step-split-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .tabs-button {
      transition: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  function initTabsSection(section) {
    var tablist = section.querySelector('[role="tablist"]');
    if (!tablist) return;

    var panels = section.querySelectorAll('[role="tabpanel"]');
    if (!panels.length) return;

    tablist.innerHTML = '';

    panels.forEach(function(panel) {
      var button = document.createElement('button');
      button.className = 'tabs-button';
      button.setAttribute('role', 'tab');
      button.setAttribute('id', panel.getAttribute('aria-labelledby'));
      button.setAttribute('aria-selected', 'false');
      button.setAttribute('aria-controls', panel.id);
      button.setAttribute('tabindex', '-1');
      button.setAttribute('data-tab-slug', panel.getAttribute('data-tab-slug') || '');

      var imageUrl = panel.getAttribute('data-tab-image');
      if (imageUrl) {
        var img = document.createElement('img');
        img.className = 'tabs-button-image';
        img.src = imageUrl;
        img.alt = '';
        img.loading = 'lazy';
        img.width = 40;
        img.height = 40;
        button.appendChild(img);
      }

      var label = document.createTextNode(panel.getAttribute('data-tab-heading') || '');
      button.appendChild(label);

      tablist.appendChild(button);
      panel.classList.remove('is-active');
      panel.hidden = true;
    });

    var buttons = tablist.querySelectorAll('[role="tab"]');

    function activateTab(button, updateUrl) {
      buttons.forEach(function(btn) {
        btn.classList.remove('is-active');
        btn.setAttribute('aria-selected', 'false');
        btn.setAttribute('tabindex', '-1');
      });

      panels.forEach(function(panel) {
        panel.classList.remove('is-active');
        panel.hidden = true;
      });

      button.classList.add('is-active');
      button.setAttribute('aria-selected', 'true');
      button.removeAttribute('tabindex');

      var panelId = button.getAttribute('aria-controls');
      var panel = document.getElementById(panelId);
      if (panel) {
        panel.classList.add('is-active');
        panel.hidden = false;
      }

      if (updateUrl !== false) {
        var slug = button.getAttribute('data-tab-slug');
        if (slug) {
          var url = new URL(window.location);
          url.searchParams.set('tab', slug);
          history.replaceState({}, '', url);
        }
      }
    }

    /* Determine initial tab from URL query param */
    var initialIndex = 0;
    var tabParam = new URLSearchParams(window.location.search).get('tab');
    if (tabParam) {
      buttons.forEach(function(btn, i) {
        if (btn.getAttribute('data-tab-slug') === tabParam) {
          initialIndex = i;
        }
      });
    }

    activateTab(buttons[initialIndex], false);

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        activateTab(button);
      });
    });

    /* Keyboard navigation */
    tablist.addEventListener('keydown', function(e) {
      var index = Array.prototype.indexOf.call(buttons, document.activeElement);
      if (index === -1) return;

      var newIndex;
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        newIndex = (index + 1) % buttons.length;
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        newIndex = (index - 1 + buttons.length) % buttons.length;
      } else if (e.key === 'Home') {
        newIndex = 0;
      } else if (e.key === 'End') {
        newIndex = buttons.length - 1;
      } else {
        return;
      }

      e.preventDefault();
      buttons[newIndex].focus();
      activateTab(buttons[newIndex]);
    });
  }

  document.querySelectorAll('.tabs-section').forEach(initTabsSection);

  document.addEventListener('shopify:section:load', function(e) {
    var section = e.target;
    if (section.classList.contains('tabs-section')) {
      initTabsSection(section);
    }
  });

  document.addEventListener('shopify:block:select', function(e) {
    var section = e.target.closest('.tabs-section');
    if (!section) return;

    var panel = e.target.closest('[role="tabpanel"]');
    if (!panel) return;

    var tabId = panel.getAttribute('aria-labelledby');
    var button = section.querySelector('#' + tabId);
    if (button) button.click();
  });
{% endjavascript %}

{% schema %}
{
  "name": "Tabs",
  "tag": "section",
  "class": "tabs-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    { "type": "tab" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["index"]
  },
  "presets": [
    {
      "name": "Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "heading": "Chairs"
          },
          "blocks": [
            {
              "type": "step",
              "settings": {
                "text": "<p>Wipe down with a damp cloth to remove dust and surface dirt.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Apply wood oil along the grain using a soft lint-free cloth.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Allow to dry for 24 hours before use. Reapply every 6 months.</p>"
              }
            }
          ]
        },
        {
          "type": "tab",
          "settings": {
            "heading": "Pagodas"
          },
          "blocks": [
            {
              "type": "step",
              "settings": {
                "text": "<p>Brush off loose debris with a soft-bristle brush.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Wash with mild soap and warm water. Rinse thoroughly.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Dry completely before storing. Cover during winter months.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
