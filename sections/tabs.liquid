{%- comment -%} Collect product tab indices for building nav and panels {%- endcomment -%}

<section class="tabs color-{{ section.settings.color_scheme }}">
  {%- assign tab_count = 0 -%}

  {%- if section.blocks.size > 0 -%}
    <div class="tabs-layout">

      {%- comment -%} Tab navigation — vertical stack with image cards {%- endcomment -%}
      <div class="tabs-nav" role="tablist" aria-label="{{ 'sections.tabs.navigation' | t }}" aria-orientation="vertical">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- assign tab_count = tab_count | plus: 1 -%}
            <button
              class="tabs-button{% if tab_count == 1 %} is-active{% endif %}"
              role="tab"
              id="tab-{{ section.id }}-{{ tab_count }}"
              aria-selected="{% if tab_count == 1 %}true{% else %}false{% endif %}"
              aria-controls="panel-{{ section.id }}-{{ tab_count }}"
              data-tab-index="{{ tab_count }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.image != blank -%}
                <span class="tabs-button-image">
                  {{ block.settings.image | image_url: width: 200 | image_tag:
                      loading: 'lazy',
                      width: block.settings.image.width,
                      height: block.settings.image.height
                  }}
                </span>
              {%- endif -%}
              <span class="tabs-button-label">{{ block.settings.heading }}</span>
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Tab panels {%- endcomment -%}
      <div class="tabs-panels">
        {%- assign panel_index = 0 -%}
        {%- assign step_counter = 0 -%}
        {%- assign panel_open = false -%}

        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- if panel_open -%}
              </div>
            {%- endif -%}
            {%- assign panel_index = panel_index | plus: 1 -%}
            {%- assign step_counter = 0 -%}
            {%- assign panel_open = true -%}
            <div
              class="tabs-panel{% if panel_index == 1 %} is-active{% endif %}"
              role="tabpanel"
              id="panel-{{ section.id }}-{{ panel_index }}"
              aria-labelledby="tab-{{ section.id }}-{{ panel_index }}"
              {% if panel_index != 1 %}hidden{% endif %}
            >
          {%- endif -%}

          {%- if block.type == 'step' -%}
            {%- assign step_counter = step_counter | plus: 1 -%}
            <div class="tabs-step" {{ block.shopify_attributes }}>
              <span class="tabs-step-number" aria-hidden="true">{{ step_counter }}</span>
              <div class="tabs-step-body">
                <div class="tabs-step-text typeset">
                  {{ block.settings.text }}
                </div>
                {%- if block.settings.image != blank and block.settings.image_2 != blank -%}
                  <div class="tabs-step-split">
                    <div class="tabs-step-split-image">
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          width: block.settings.image.width,
                          height: block.settings.image.height
                      }}
                    </div>
                    <div class="tabs-step-split-image">
                      {{ block.settings.image_2 | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          width: block.settings.image_2.width,
                          height: block.settings.image_2.height
                      }}
                    </div>
                  </div>
                {%- elsif block.settings.image != blank -%}
                  <div class="tabs-step-media">
                    {{ block.settings.image | image_url: width: 800 | image_tag:
                        loading: 'lazy',
                        width: block.settings.image.width,
                        height: block.settings.image.height,
                        class: 'tabs-step-image'
                    }}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if panel_open -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .tabs {
    width: 80%;
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--spacing-4) 0;
  }

  @media (min-width: 750px) {
    .tabs {
      padding: var(--spacing-5) 0;
    }
  }

  /* Side-by-side layout: nav left, panels right */
  .tabs-layout {
    display: grid;
    gap: var(--spacing-3);
  }

  @media (min-width: 900px) {
    .tabs-layout {
      grid-template-columns: 2fr 3fr;
      gap: var(--spacing-3);
    }
  }

  /* Vertical tab navigation */
  .tabs-nav {
    display: flex;
    flex-direction: row;
    gap: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  @media (min-width: 900px) {
    .tabs-nav {
      flex-direction: column;
      overflow-x: visible;
    }
  }

  .tabs-button {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--spacing-2) 0;
    text-align: left;
    border-top: 1px solid var(--color-text);
    white-space: nowrap;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  @media (min-width: 900px) {
    .tabs-button {
      white-space: normal;
    }
  }

  .tabs-button.is-active {
    color: var(--color-text);
    background-color: var(--color-input-bg);
  }

  .tabs-button:hover {
    color: var(--color-text);
  }

  .tabs-button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .tabs-button-image {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .tabs-button-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tabs-button-label {
    font-family: var(--font-heading);
    font-size: var(--font-medium-size);
  }

  /* Panels */
  .tabs-panel[hidden] {
    display: none;
  }

  /* Steps — vertically stacked */
  .tabs-step {
    display: flex;
    gap: var(--spacing-2);
    align-items: flex-start;
    margin-bottom: var(--spacing-3);
  }

  .tabs-step:last-child {
    margin-bottom: 0;
  }

  .tabs-step-number {
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: var(--font-large-size);
    line-height: var(--font-large-height);
  }

  .tabs-step-body {
    flex: 1;
    min-width: 0;
  }

  .tabs-step-text {
    max-width: 80ch;
  }

  .tabs-step-media {
    margin-top: var(--spacing-2);
  }

  .tabs-step-media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .tabs-step-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Split step — two portrait images side by side */
  .tabs-step-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-1);
    margin-top: var(--spacing-2);
  }

  .tabs-step-split-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .tabs-step-split-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .tabs-button {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.tabs-section').forEach(function(section) {
    var tablist = section.querySelector('[role="tablist"]');
    if (!tablist) return;

    var buttons = tablist.querySelectorAll('[role="tab"]');
    var panels = section.querySelectorAll('[role="tabpanel"]');

    function activateTab(button) {
      buttons.forEach(function(btn) {
        btn.classList.remove('is-active');
        btn.setAttribute('aria-selected', 'false');
        btn.setAttribute('tabindex', '-1');
      });

      panels.forEach(function(panel) {
        panel.classList.remove('is-active');
        panel.hidden = true;
      });

      button.classList.add('is-active');
      button.setAttribute('aria-selected', 'true');
      button.removeAttribute('tabindex');

      var panelId = button.getAttribute('aria-controls');
      var panel = document.getElementById(panelId);
      if (panel) {
        panel.classList.add('is-active');
        panel.hidden = false;
      }
    }

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        activateTab(button);
      });
    });

    /* Keyboard navigation — vertical orientation uses ArrowUp/ArrowDown */
    tablist.addEventListener('keydown', function(e) {
      var index = Array.prototype.indexOf.call(buttons, document.activeElement);
      if (index === -1) return;

      var newIndex;
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        newIndex = (index + 1) % buttons.length;
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        newIndex = (index - 1 + buttons.length) % buttons.length;
      } else if (e.key === 'Home') {
        newIndex = 0;
      } else if (e.key === 'End') {
        newIndex = buttons.length - 1;
      } else {
        return;
      }

      e.preventDefault();
      buttons[newIndex].focus();
      activateTab(buttons[newIndex]);
    });

    /* Set initial tabindex for roving tabindex pattern */
    buttons.forEach(function(btn, i) {
      if (i > 0) btn.setAttribute('tabindex', '-1');
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Tabs",
  "tag": "section",
  "class": "tabs-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tab heading",
          "default": "Product name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Tab image"
        }
      ]
    },
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Step text",
          "default": "<p>Describe this care step.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Second image (split layout)"
        }
      ]
    }
  ],
  "disabled_on": {
    "templates": ["index"]
  },
  "presets": [
    {
      "name": "Tabs",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "heading": "Chairs"
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "<p>Wipe down with a damp cloth to remove dust and surface dirt.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "<p>Apply wood oil along the grain using a soft lint-free cloth.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "<p>Allow to dry for 24 hours before use. Reapply every 6 months.</p>"
          }
        },
        {
          "type": "product",
          "settings": {
            "heading": "Pagodas"
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "<p>Brush off loose debris with a soft-bristle brush.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "<p>Wash with mild soap and warm water. Rinse thoroughly.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "text": "<p>Dry completely before storing. Cover during winter months.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
