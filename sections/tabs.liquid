{%- comment -%} Tabs section — JS builds nav buttons from panel data attributes {%- endcomment -%}

<div class="tabs color-{{ section.settings.color_scheme }}">
  {%- if section.blocks.size > 0 -%}
    <div class="tabs-layout">
      <div class="tabs-nav">
        <div class="tabs-nav-viewport">
          <div class="tabs-nav-container" role="tablist" aria-label="{{ 'sections.tabs.navigation' | t }}"></div>
        </div>
      </div>
      <div class="tabs-panels">
        {% content_for 'blocks' %}
      </div>
    </div>
  {%- endif -%}
</div>

<script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>

<noscript>
  <style>.tabs-panel { display: block !important; }</style>
</noscript>

{% stylesheet %}
  .tabs {
    width: 100%;
    padding: var(--spacing-4) var(--spacing-2);
  }

  .tabs-panels {
    padding-inline: 0;
  }

  @media (min-width: 900px) {
    .tabs {
      width: 83%;
      max-width: 1200px;
      margin-inline: auto;
      padding: var(--spacing-5) 0;
    }
  }

  /* Side-by-side layout: nav left, panels right */
  .tabs-layout {
    display: grid;
    gap: var(--spacing-3);
  }

  @media (min-width: 900px) {
    .tabs-layout {
      display: grid;
      grid-template-columns: repeat(10, 1fr);
      column-gap: 0;
    }

    .tabs-nav {
      grid-column: 1 / span 3;
      position: sticky;
      top: var(--header-height, 80px);
      align-self: start;
    }

    .tabs-panels {
      grid-column: 5 / span 6;
    }
  }

  /* Tab navigation — Embla slider on mobile/tablet */
  .tabs-nav {
    border-top: 1px solid var(--color-text);
  }

  .tabs-nav-viewport {
    overflow: hidden;
  }

  .tabs-nav-container {
    display: flex;
  }

  .tabs-button {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    color: var(--color-text);
    flex: 0 0 50%;
    min-width: 0;
    border-right: 1px solid var(--color-text);
  }

  @media (min-width: 600px) and (max-width: 899px) {
    .tabs-button {
      flex: 0 0 33.333%;
      border-right: 1px solid var(--color-text);
    }

    .tabs-button:last-child {
      border-right: 0;
    }
  }

  /* Desktop: 2-column grid instead of slider */
  @media (min-width: 900px) {
    .tabs-nav-viewport {
      overflow: visible;
    }

    .tabs-nav-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .tabs-button {
      flex: none;
      border-right: 0;
    }

    /* Horizontal divider between rows (not on last row) */
    .tabs-button:not(:nth-last-child(-n+2)) {
      border-bottom: 1px solid var(--color-text);
    }

    /* Vertical divider between columns */
    .tabs-button:nth-child(odd):not(:last-child) {
      border-right: 1px solid var(--color-text);
    }
  }

  .tabs-button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .tabs-button-image {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 1;
    transition: opacity var(--transition-fast);
  }

  .tabs-button-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* On hover/active: hide image, show centered label with bg */
  .tabs-button:hover .tabs-button-image,
  .tabs-button.is-active .tabs-button-image {
    opacity: 0;
  }

  .tabs-button.is-active {
    background-color: var(--color-input-bg);
  }

  /* Label — centered, hidden by default, visible on hover and when active */
  .tabs-button-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-s);
    font-size: var(--font-mini-size);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .tabs-button:hover .tabs-button-label,
  .tabs-button.is-active .tabs-button-label {
    opacity: 1;
  }

  /* Panels — hidden by default, JS activates the first */
  .tabs-panel {
    display: none;
    counter-reset: step-counter;
  }

  .tabs-panel.is-active {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  /* Steps — number left, content (label + text + images) right */
  .tabs-step {
    counter-increment: step-counter;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-2);
    align-items: baseline;
    margin-bottom: var(--spacing-3);
  }

  .tabs-step:last-child {
    margin-bottom: 0;
  }

  .tabs-step-number {
    font-family: var(--font-heading);
    font-size: var(--font-large-size);
    line-height: var(--font-large-height);
  }

  .tabs-step-number::before {
    content: counter(step-counter);
  }

  .tabs-step-content {
    display: flex;
    flex-direction: column;
  }

  .tabs-step-label {
    font-size: var(--font-mini-size);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-2);
  }

  .tabs-step-text {
    max-width: 60ch;
  }

  .tabs-step-media {
    margin-top: var(--spacing-1);
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .tabs-step-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Split step — two portrait images side by side */
  .tabs-step-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-1);
    margin-top: var(--spacing-1);
  }

  .tabs-step-split-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .tabs-step-split-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .tabs-button {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  function initTabsSection(section) {
    var tablist = section.querySelector('[role="tablist"]');
    var viewport = section.querySelector('.tabs-nav-viewport');
    if (!tablist || !viewport) return;

    var panels = section.querySelectorAll('[role="tabpanel"]');
    if (!panels.length) return;

    /* Clear previous buttons (handles editor re-renders) */
    tablist.innerHTML = '';

    /* Build tab buttons from panel data attributes */
    panels.forEach(function(panel, i) {
      var button = document.createElement('button');
      button.className = 'tabs-button' + (i === 0 ? ' is-active' : '');
      button.setAttribute('role', 'tab');
      button.setAttribute('id', panel.getAttribute('aria-labelledby'));
      button.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      button.setAttribute('aria-controls', panel.id);
      if (i > 0) button.setAttribute('tabindex', '-1');

      var imageUrl = panel.getAttribute('data-tab-image-url');
      if (imageUrl) {
        var imgSpan = document.createElement('span');
        imgSpan.className = 'tabs-button-image';
        var img = document.createElement('img');
        img.src = imageUrl;
        img.loading = 'lazy';
        img.width = panel.getAttribute('data-tab-image-width') || '';
        img.height = panel.getAttribute('data-tab-image-height') || '';
        imgSpan.appendChild(img);
        button.appendChild(imgSpan);
      }

      var label = document.createElement('span');
      label.className = 'tabs-button-label';
      label.textContent = panel.getAttribute('data-tab-heading') || '';
      button.appendChild(label);

      tablist.appendChild(button);

      /* Set panel initial state */
      if (i === 0) {
        panel.classList.add('is-active');
        panel.hidden = false;
      } else {
        panel.classList.remove('is-active');
        panel.hidden = true;
      }
    });

    var buttons = tablist.querySelectorAll('[role="tab"]');

    function activateTab(button) {
      buttons.forEach(function(btn) {
        btn.classList.remove('is-active');
        btn.setAttribute('aria-selected', 'false');
        btn.setAttribute('tabindex', '-1');
      });

      panels.forEach(function(panel) {
        panel.classList.remove('is-active');
        panel.hidden = true;
      });

      button.classList.add('is-active');
      button.setAttribute('aria-selected', 'true');
      button.removeAttribute('tabindex');

      var panelId = button.getAttribute('aria-controls');
      var panel = document.getElementById(panelId);
      if (panel) {
        panel.classList.add('is-active');
        panel.hidden = false;
      }
    }

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        activateTab(button);
      });
    });

    /* Keyboard navigation */
    tablist.addEventListener('keydown', function(e) {
      var index = Array.prototype.indexOf.call(buttons, document.activeElement);
      if (index === -1) return;

      var newIndex;
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        newIndex = (index + 1) % buttons.length;
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        newIndex = (index - 1 + buttons.length) % buttons.length;
      } else if (e.key === 'Home') {
        newIndex = 0;
      } else if (e.key === 'End') {
        newIndex = buttons.length - 1;
      } else {
        return;
      }

      e.preventDefault();
      buttons[newIndex].focus();
      activateTab(buttons[newIndex]);
    });

    /* Embla slider for tablet/mobile */
    var emblaInstance = null;
    var desktopMql = window.matchMedia('(min-width: 900px)');

    function initEmbla() {
      if (typeof window.EmblaCarousel === 'undefined') return;
      if (emblaInstance) return;
      var slideCount = tablist.querySelectorAll('[role="tab"]').length;
      var middleIndex = Math.floor(slideCount / 2);
      emblaInstance = window.EmblaCarousel(viewport, {
        align: 'center',
        loop: true,
        startIndex: middleIndex
      });
    }

    function destroyEmbla() {
      if (emblaInstance) {
        emblaInstance.destroy();
        emblaInstance = null;
      }
    }

    function handleBreakpoint(e) {
      if (e.matches) {
        destroyEmbla();
      } else {
        initEmbla();
      }
    }

    desktopMql.addEventListener('change', handleBreakpoint);
    handleBreakpoint(desktopMql);

    /* If Embla script hasn't loaded yet, wait for it */
    if (!desktopMql.matches && typeof window.EmblaCarousel === 'undefined') {
      var script = document.querySelector('script[src*="embla-carousel"]');
      if (script) {
        script.addEventListener('load', function() {
          if (!desktopMql.matches) initEmbla();
        }, { once: true });
      }
    }
  }

  /* Initialize on page load */
  document.querySelectorAll('.tabs-section').forEach(initTabsSection);

  /* Re-initialize when the theme editor re-renders the section */
  document.addEventListener('shopify:section:load', function(e) {
    var section = e.target;
    if (section.classList.contains('tabs-section')) {
      initTabsSection(section);
    }
  });

  /* Switch to the correct tab when a block is selected in the editor */
  document.addEventListener('shopify:block:select', function(e) {
    var section = e.target.closest('.tabs-section');
    if (!section) return;

    var panel = e.target.closest('[role="tabpanel"]');
    if (!panel) return;

    var tabId = panel.getAttribute('aria-labelledby');
    var button = section.querySelector('#' + tabId);
    if (button) button.click();
  });
{% endjavascript %}

{% schema %}
{
  "name": "Tabs",
  "tag": "section",
  "class": "tabs-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    { "type": "tab" }
  ],
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["index"]
  },
  "presets": [
    {
      "name": "Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "heading": "Chairs"
          },
          "blocks": [
            {
              "type": "step",
              "settings": {
                "text": "<p>Wipe down with a damp cloth to remove dust and surface dirt.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Apply wood oil along the grain using a soft lint-free cloth.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Allow to dry for 24 hours before use. Reapply every 6 months.</p>"
              }
            }
          ]
        },
        {
          "type": "tab",
          "settings": {
            "heading": "Pagodas"
          },
          "blocks": [
            {
              "type": "step",
              "settings": {
                "text": "<p>Brush off loose debris with a soft-bristle brush.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Wash with mild soap and warm water. Rinse thoroughly.</p>"
              }
            },
            {
              "type": "step",
              "settings": {
                "text": "<p>Dry completely before storing. Cover during winter months.</p>"
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
